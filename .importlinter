# BI-Agent v0.3.0 — 4 层架构契约
# 任何 PR 修改下方分层都必须经资深评审；CI 强制不可绕过。
[importlinter]
root_package = bi_agent
include_external_packages = False

# ── Contract 1: 4 层方向严格自上而下 ──
# v0.3.0 阶段：bi_agent.routers 占据 api 层（v0.3.3 改名为 bi_agent.api）；
#              bi_agent.services / bi_agent.adapters 在 v0.3.1 / v0.3.2 落地，
#              当前用占位语法允许它们暂不存在（include_external_packages=False 兜底）。
[importlinter:contract:layered-architecture]
name = routers → services → repositories | adapters → models
type = layers
layers =
    bi_agent.routers | bi_agent.api
    bi_agent.services
    bi_agent.repositories | bi_agent.adapters
    bi_agent.models

# ── Contract 2: models 是叶子节点（不得 import bi_agent 内任何包，含 core）──
[importlinter:contract:models-is-leaf]
name = models 不得 import bi_agent 内部任何其他包（纯叶子）
type = forbidden
source_modules = bi_agent.models
forbidden_modules =
    bi_agent.core
    bi_agent.config
    bi_agent.routers
    bi_agent.repositories

# ── Contract 3: core 不得 import models（已生效）──
# FIXME-v0.3.3: 此 contract 当前仅锁 models 方向。v0.3.0 阶段 core/ 内部仍含 6 个
# "未来 service" 文件（auth_utils / llm_client / multi_agent / sql_agent / catalog_loader /
# doc_rag / prompts），它们合法 import bi_agent.repositories；待 v0.3.1~v0.3.2 把它们搬到
# services/ 与 adapters/ 后，本 contract 在 v0.3.3 升级为完整 forbidden_modules：
#   bi_agent.api, bi_agent.services, bi_agent.repositories, bi_agent.adapters
[importlinter:contract:core-no-models]
name = core 是横切工具，禁止依赖 models（防止工具拐回业务数据形状）
type = forbidden
source_modules = bi_agent.core
forbidden_modules =
    bi_agent.models
    bi_agent.routers

# ── Contract 4: repositories / adapters 之间不互相依赖 ──
[importlinter:contract:repos-no-business]
name = repositories 不得 import routers / services / adapters / 任何业务编排层
type = forbidden
source_modules = bi_agent.repositories
forbidden_modules = bi_agent.routers, bi_agent.services, bi_agent.adapters

# ── Contract 5（v0.3.2 新增）：adapters 不得 import services / routers / repositories ──
[importlinter:contract:adapters-no-business]
name = adapters 是叶子实现，禁止依赖业务编排层（services / routers / repositories）
type = forbidden
source_modules = bi_agent.adapters
forbidden_modules = bi_agent.services, bi_agent.routers, bi_agent.repositories
