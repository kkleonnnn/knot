# ── LLM API Keys (fill in the ones you use) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=...

# ── Optional: custom base URLs (e.g. for proxies) ─────────────────────
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Default LLM model ─────────────────────────────────────────────────
DEFAULT_MODEL=claude-haiku-4-5-20251001

# ── Database (Apache Doris / MySQL compatible) ────────────────────────
DB_HOST=localhost
DB_PORT=9030
DB_USER=root
DB_PASSWORD=
DB_DATABASE=mydb

# ── JWT secret (change in production!) ───────────────────────────────
JWT_SECRET=bi-agent-secret-change-in-production

# ── v0.4.5: Field-level encryption master key (REQUIRED) ──────────────
# 应用层加密 6 类敏感字段（API Key / DB 密码）的 Fernet 主密钥。
# 缺失 → 启动失败（fail-fast，无 fallback）。
# 生成: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ 务必备份至独立保险位置；丢失会导致历史加密数据永久不可读
BIAGENT_MASTER_KEY=

# ── SQLite path for app metadata ──────────────────────────────────────
# SQLITE_DB_PATH=./data/bi_agent.db

# ── Tuning knobs ──────────────────────────────────────────────────────
AGENT_MAX_STEPS=5
SCHEMA_FILTER_MAX_TABLES=10
RAG_TOP_K=5
FEW_SHOT_MAX_EXAMPLES=4
