# ── LLM API Keys (fill in the ones you use) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=...

# ── Optional: custom base URLs (e.g. for proxies) ─────────────────────
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Default LLM model ─────────────────────────────────────────────────
# v0.6.0.8 MUST-2：默认切到 OpenRouter 通道（OR-only catalog；1 个 key 通所有模型）
# 内测期建议 OR；direct provider keys 保留至 Day 28+ Phase B 三方会议拍板是否清理
DEFAULT_MODEL=anthropic/claude-haiku-4.5

# ── Database (Apache Doris / MySQL compatible) ────────────────────────
DB_HOST=localhost
DB_PORT=9030
DB_USER=root
DB_PASSWORD=
DB_DATABASE=knot_demo

# ── JWT secret (v0.6.0.8 MUST-1: 必须替换；fail-fast 拦默认占位) ──────
# 生成: openssl rand -hex 32  （32 字节十六进制 = 64 字符；安全建议 ≥16 字符）
# 缺失 / 用历史默认占位 / 长度 < 16 → 启动 sys.exit(1) + 友好彩色提示
JWT_SECRET=

# ── v0.4.5: Field-level encryption master key (REQUIRED) ──────────────
# 应用层加密 6 类敏感字段（API Key / DB 密码）的 Fernet 主密钥。
# 缺失 → 启动失败（fail-fast，无 fallback）。
# 生成: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ 务必备份至独立保险位置；丢失会导致历史加密数据永久不可读
# v0.6.0：env 名 KNOT_MASTER_KEY（v0.5.x 双源兼容已撤回；详 CHANGELOG v0.6.0）
KNOT_MASTER_KEY=

# ── v0.4.6: 审计日志 ──────────────────────────────────────────────
# retention 默认 90 天，admin 可在 PUT /api/admin/audit-config 调整（7~3650）
# 配置存于 app_settings.audit.retention_days（不读 env，仅 admin 路由）
# 清理脚本：python3 -m knot.scripts.purge_audit_log [--dry-run]

# ── SQLite path for app metadata ──────────────────────────────────────
# SQLITE_DB_PATH=./data/knot.db

# ── Tuning knobs ──────────────────────────────────────────────────────
AGENT_MAX_STEPS=5
SCHEMA_FILTER_MAX_TABLES=10
RAG_TOP_K=5
FEW_SHOT_MAX_EXAMPLES=4
